<!--Pending Request-->
<form asp-action="index" method="post">

    <div class="container d-flex justify-content-center" style="margin-top:6%">

        <!-- Main Border -->
        <div class="PNRMainBoarder p-4">

            <!-- Main Row -->
            <div class="row">

                <!-- LEFT SIDE | Pending Request List -->
                <div class="col-12 col-md-6 col-sm-12 col-xxl-6 col-xl-6 order-md-1 order-lg-1 col-xl-1 col-xxl-1 order-2">

                    <!-- Title -->
                    <div class="text-start mb-4 pendingrequest">
                        <label style="color:gray; font-size:100%; font-weight:bold">
                            PENDING REQUEST
                        </label>
                    </div>

                    <!-- Pending Request Container -->
                    <div class="pending-container">

                        <!-- CARD 01 -->
                        <div class="request-card">

                            <!-- Left Icon -->
                            <div class="icon-box d-flex justify-content-center align-items-center">

                                <div class="pending-user-icon">

                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         width="22"
                                         height="22"
                                         fill="none"
                                         stroke="white"
                                         stroke-width="2"
                                         stroke-linecap="round"
                                         stroke-linejoin="round"
                                         viewBox="0 0 24 24">

                                        <!-- Head -->
                                        <circle cx="12" cy="8" r="3"></circle>

                                        <!-- Body -->
                                        <path d="M6 19c0-3 2.5-5 6-5s6 2 6 5"></path>

                                    </svg>

                                </div>

                            </div>

                            <!-- Right Content -->
                            <div class="info-box text-start ms-3">

                                <div>
                                    <label style="font-weight:bold">
                                        Sandesh Piyumantha
                                    </label>
                                </div>

                                <div>
                                    <label>EPF001</label>
                                </div>

                            </div>

                        </div>

                        <!-- CARD 02 -->
                        <div class="request-card">

                            <!-- Left Icon -->
                            <div class="icon-box d-flex justify-content-center align-items-center">

                                <div class="pending-user-icon">

                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         width="22"
                                         height="22"
                                         fill="none"
                                         stroke="white"
                                         stroke-width="2"
                                         stroke-linecap="round"
                                         stroke-linejoin="round"
                                         viewBox="0 0 24 24">

                                        <!-- Head -->
                                        <circle cx="12" cy="8" r="3"></circle>

                                        <!-- Body -->
                                        <path d="M6 19c0-3 2.5-5 6-5s6 2 6 5"></path>

                                    </svg>

                                </div>

                            </div>

                            <!-- Right Content -->
                            <div class="info-box text-start ms-3">

                                <div>
                                    <label style="font-weight:bold">
                                        Sandesh Piyumantha
                                    </label>
                                </div>

                                <div>
                                    <label>EPF001</label>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6 order-md-2 order-lg-2 col-xl-2 col-xxl-2 order-1">

                    <div class="row justify-content-center text-center">
                        <!-- Main Icon -->
                        <div class="d-flex justify-content-center">
                            <!-- Pending Request Main Icon -->
                            <div style="
                                width:80px;
                                height:80px;
                                background:#f59e0b;
                                border-radius:50%;
                                display:flex;
                                justify-content:center;
                                align-items:center;
                                box-shadow:0 10px 25px rgba(245,158,11,0.3);
                                ">

                                <!-- CLOCK SVG -->
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="38"
                                     height="38"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke="white"
                                     stroke-width="2.2"
                                     stroke-linecap="round"
                                     stroke-linejoin="round">

                                    <!-- Outer circle -->
                                    <circle cx="12" cy="12" r="9"></circle>

                                    <!-- Clock hands -->
                                    <path d="M12 7v5l3 2"></path>

                                </svg>

                            </div>

                        </div>

                        <div class="col-12 col-sm-12 col-md-12 col-xl-12 col-xxl-12" style="padding-top:3%;padding-bottom:2%">
                            <label style="font-weight:bold;font-size:140%">Pending Request</label>
                        </div>

                        <div class="PNDRBorder">
                            <label style="font-size:100%;color:#f59e0b;font-weight:bold"> 3 REQUEST PENDING</label>
                        </div>


                    </div>

                    <!--section 2 of Right side-->
                    <!--Search-->
                    <div class="row" style="padding-top:12%;font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;font-weight:bold;color:gray">
                        <div class="col-12 col-sm-12 col-md-12 col-xl-12 col-xxl-12">
                            <label>Search by using EPF</label>
                        </div>
                    </div>

                    <div class="row" style="padding-top:2%">

                        <div class="col-12 col-sm-12 col-md-9 col-xl-9 col-xxl-9">
                            <div class="position-relative">
                                <input type="text" class="form-control ps-5" placeholder="Type EPF to search..." />
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="gray"
                                     class="position-absolute top-50 start-0 translate-middle-y ms-2"
                                     viewBox="0 0 24 24">
                                    <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                                </svg>
                            </div>
                        </div>
                        <div class="col-12 col-sm-12 col-md-3 col-xl-3 col-xxl-3 searchButton">
                            <button type="submit" class="btn btn-primary searchButtonwidth" style="background-color:black;color:white">Search</button>
                        </div>

                    </div>

                    <!--section 3 of Right side-->
                  
                    <div class="row" style="padding-top:8%">
                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <label style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;font-weight:bold;color:gray">Employee Name</label>
                            </div>
                            <div style="padding-top:2%">
                                <div class="position-relative">
                                    <input type="text" class="form-control ps-5" placeholder="Employee Name" />
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="gray"
                                         class="position-absolute top-50 start-0 translate-middle-y ms-2"
                                         viewBox="0 0 24 24">
                                        <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                                    </svg>
                                </div>

                            </div>
                        </div>

                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <label style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;font-weight:bold;color:gray">Reason</label>
                            </div>
                            <div style="padding-top:2%">
                                <div class="position-relative">
                                    <input type="text" class="form-control ps-5" placeholder="Reason" />
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="gray"
                                         class="position-absolute top-50 start-0 translate-middle-y ms-2"
                                         viewBox="0 0 24 24">
                                        <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                                    </svg>
                                </div>

                            </div>
                        </div>
                    </div>


                    <!--section 4 of Right side-->

                    <div class="row" style="padding-top:8%">
                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <label style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;font-weight:bold;color:gray">Out Time</label>
                            </div>
                            <div style="padding-top:2%">
                                <div class="position-relative">
                                    <input type="time" class="form-control" style="font-size:100%;opacity:60%">

                                </div>

                            </div>
                        </div>

                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <label style="font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;font-weight:bold;color:gray">In Time</label>
                            </div>
                            <div style="padding-top:2%">
                                <div class="position-relative">
                                    <input type="time" class="form-control" style="font-size:100%;opacity:60%">

                                </div>

                            </div>
                        </div>
                    </div>


                    <!--section 5 of Right side-->

                    <div class="row" style="padding-top:8%">
                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <button type="submit" style="width:100%;font-weight:bold;background-color:#FF2056" class="btn btn-danger">REJECT</button>

                            </div>
                           
                        </div>

                        <div class="col-12 col-sm-12 col-md-6 col-xl-6 col-xxl-6" style="padding-top:2%">
                            <div>
                                <button type="submit" style="width:100%;font-weight:bold;background-color:#1DA577" class="btn btn-success">APPROVE</button>

                            </div>
                           
                        </div>
                    </div>

                   

                </div>

            </div>

        </div>

    </div>

</form>