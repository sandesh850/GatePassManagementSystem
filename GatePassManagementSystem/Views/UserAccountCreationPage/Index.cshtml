                                 class="position-absolute top-50 start-0 translate-middle-y ms-2"
                                 viewBox="0 0 24 24">
                                <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                            </svg>
                        </div>

                    </div>
                </div>

                <div class="col-md-1 col-1 col-sm-1 col-xl-1 col-xxl-1"></div>
                <div class="col-5 col-md-5 col-sm-5 col-xl-5 col-xxl-5 text-start">
                    <div>
                        <label class="lblstyles" style="color:black">Reporting manager</label>
                    </div>
                    <div style="padding-top:2%">
                        <div class="position-relative">

                            <!-- Reporting Manager SVG Icon -->
                            <span class="dropdown-icon">

                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="20"
                                     height="20"
                                     fill="gray"
                                     viewBox="0 0 24 24">

                                    <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />

                                </svg>

                            </span>

                            <!-- Dropdown -->
                            <select class="form-select custom-select">
                                <option selected>Select Reporting Manager</option>
                                <option>Dukantha Weerasinghe</option>
                                <option>Yashodani Nedurana</option>
                                <option>Thissa Mahanpitiya</option>
                            </select>
                        </div>

                    </div>
                </div>

               
            </div>

           
            <!--row 10 | btnCreateAccount-->
            <div class="row" style="padding-top:4%;padding-bottom:4%">

                <div class="col-12 col-sm-12 col-md-12 col-xl-12 col-xxl-12">

                    <button type="submit" class="btn btn-primary"
                            style="font-weight:bold;width:90%; height:100%; font-size:110%; letter-spacing:2px; border-radius:15px;">

                        Create Account

                    </button>

                </div>
            </div>
           

        </div>
